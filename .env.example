# Rankivo — SEO AI Tools — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All values are optional — Rankivo works out of the box with
# sensible defaults. Only set what you need.

# --- AI Provider Settings ---
# Set API keys to enable providers. Rankivo auto-detects which
# ones are available. At least one provider is needed for
# article generation and AI recommendations.
#
# Default provider to use: "ollama", "openai", "anthropic", "gemini"
DEFAULT_AI_PROVIDER=ollama

# Ollama (local, free) — Install from https://ollama.ai then: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenAI — Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic Claude — Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini — Get your key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Database Settings ---
# Leave empty for SQLite (data/rankivo.db). Set for PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/rankivo
DATABASE_URL=

# --- Authentication ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=rankivo
SECRET_KEY=rankivo-change-me-in-production

# --- Server Settings ---
PORT=5500

# --- Language Settings ---
# Supported: "en" (English), "fa" (Persian/Farsi)
DEFAULT_LANGUAGE=fa

# --- Google Trends Settings ---
# No API key required — uses pytrends library.
GOOGLE_TRENDS_HL=en-US
GOOGLE_TRENDS_TZ=360

# --- Bing SEO Settings ---
# Optional. Get your key at https://www.bing.com/webmasters
BING_API_KEY=5989f9a01c8345a493fb308ed31d5af2
PAGESPEED_API_KEY=

# Optional. Get a key at https://developers.google.com/speed/docs/insights/v5/get-started
SERPER_API_KEY=

# --- LLM Keyword Intelligence ---
# Embedding model for semantic clustering (via Ollama)
EMBEDDING_MODEL=nomic-embed-text
# Max keywords to estimate difficulty for
DIFFICULTY_SAMPLE_SIZE=5

# --- Email Notifications (SMTP) ---
# For Gmail: use an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- Slack Notifications ---
# Create a webhook at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Days before a deadline to send notifications (default: 3)
NOTIFICATION_DAYS_BEFORE=3
